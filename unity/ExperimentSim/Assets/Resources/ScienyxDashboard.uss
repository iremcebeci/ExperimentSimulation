:root {
  --base-clr: #f1f4f9;
  --line-clr: #c2c2c2;
  --boxes-bg-clr: #ffffff;
  --hover-clr: #243567;
  --text-clr: #1E1E1E;
  --accent-clr: #243567;
  --secondary-text-clr: #F5F5F5;
  --logout-clr: #d32f2f;
}

.root{
  flex-direction: row;
  width: 100%;
  height: 100%;
  background-color: var(--base-clr);
  color: var(--text-clr);
}

#Root {
  flex-direction: row;
  width: 100%;
  height: 100%;
}

/* main  */
.main{
  flex-grow: 1;
  height: 100%;
  padding: 20px;
  box-sizing: border-box;
}

.main-content{
  padding: 24px;
  background-color: var(--boxes-bg-clr);
  border-radius: 8px;
  box-sizing: border-box;
}

.main-title{
  font-size: 24px;
  font-weight: bold;
  color: var(--text-clr);
  margin-bottom: 8px;
}

.main-subtitle{
  font-size: 14px;
  color: var(--text-clr);
  opacity: 0.7;
}

/* sidebar */
.sidebar{
  box-sizing: border-box;
  flex-direction: column;
  width: 250px;
  height: 100%;
  padding-top: 12px;
  padding-bottom: 0px;
  padding-left: 14px;
  padding-right: 14px;

  background-color: var(--boxes-bg-clr);

  border-right-width: 1px;
  border-right-style: solid;
  border-right-color: var(--line-clr);

  overflow: hidden;
  white-space: nowrap;
}


.sidebar.close{
  width: 60px;
  padding-left: 5px;
  padding-right: 5px;
}

.sidebar.close .logo{
  display: none;
}

.sidebar.close .menu-text{
  display: none;
}

.sidebar.close .menu-chevron{
  display: none;
}


.sidebar{
  transition-property: width, padding-left, padding-right;
  transition-duration: 0.3s;
  transition-timing-function: ease;
}


.menu{
  flex-grow: 1;
  flex-shrink: 1;
  min-height: 0;
  flex-basis: auto;
}


.menu > .unity-scroll-view__content-viewport{
  flex-grow: 1;
}

.menu > .unity-scroll-view__content-container{
  align-items: stretch;
  padding-right: 0px;
  min-height: auto;
}


.sidebar-footer{
  flex-direction: column;
  flex-shrink: 0;
  padding-top: 8px;
  padding-bottom: 12px;
}


.sidebar-header-item{
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
  gap: 6px;
}


.logo{
  font-weight: 600;
  font-size: 16px;
  padding-top: 8px;
  padding-bottom: 8px;
  padding-left: 8px;
  padding-right: 8px;

  border-radius: 6px;
  color: var(--text-clr);
  white-space: nowrap;
  overflow: visible;
}


.toggle-btn{
  margin-left: auto;
  padding-top: 8px;
  padding-bottom: 8px;
  padding-left: 8px;
  padding-right: 8px;

  border-radius: 6px;
  background-color: transparent;

  border-width: 0px;
  cursor: link;
}


.toggle-btn.rotate{
  transform-origin: center;
  rotate: 180deg;
  cursor: link;
}


#ToggleIcon{
  transition-property: rotate;
  transition-duration: 0.3s;
  transition-timing-function: ease;
}



.menu-item{
  width: auto;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  gap: 10px;

  padding-top: 10px;
  padding-bottom: 10px;
  padding-left: 10px;
  padding-right: 10px;

  border-radius: 6px;
  background-color: transparent;
  border-width: 0px;

  cursor: pointer;
  align-self: stretch;
  box-sizing: border-box;
  min-width: 0px;
  cursor: link;
}


.dropdown-btn{
  text-align: left;
  cursor: link;
}


.menu-text{
  flex-grow: 1;
  flex-shrink: 1;
  flex-basis: 0;
  min-width: 0;
  color: var(--text-clr);
  text-align: left;
  font-size: 14px;
  -unity-text-align: middle-left;
}


.menu-icon{
  width: 20px;
  height: 20px;
  flex-shrink: 0;

  -unity-background-scale-mode: scale-to-fit;

  -unity-background-image-tint-color: var(--text-clr);
}


.menu-chevron{
  width: 18px;
  height: 18px;
  margin-left: auto;
  -unity-background-scale-mode: scale-to-fit;
  -unity-background-image-tint-color: var(--text-clr);

  transition-property: rotate;
  transition-duration: 0.3s;
  transition-timing-function: ease;
}

.menu-item:hover,
.dropdown-btn:hover{
  background-color: var(--hover-clr);
  cursor: link;
}

.menu-item:hover .menu-text,
.dropdown-btn:hover .menu-text{
  color: var(--secondary-text-clr);
  cursor: link;
}

.menu-item:hover .menu-icon,
.dropdown-btn:hover .menu-icon,
.menu-item:hover .menu-chevron,
.dropdown-btn:hover .menu-chevron{
  -unity-background-image-tint-color: var(--secondary-text-clr);
  cursor: link;
}



.menu-item.active{
  background-color: var(--accent-clr);
}

.menu-item.active .menu-text{
  color: var(--secondary-text-clr);
}

.menu-item.active .menu-icon,
.menu-item.active .menu-chevron{
  -unity-background-image-tint-color: var(--secondary-text-clr);
}


.sub-menu{
  display: none;
  flex-direction: column;
  padding-left: 26px;
  padding-top: 4px;
  padding-bottom: 4px;
}

.sub-menu.show{
  display: flex;
}

.sub-menu-item{
  width: 90%;
  text-align: left;
  font-size: 13px;

  padding-top: 8px;
  padding-bottom: 8px;
  padding-left: 10px;
  padding-right: 10px;

  border-radius: 6px;
  background-color: transparent;
  border-width: 0px;

  cursor: link;
  color: var(--text-clr);
  -unity-text-align: middle-left;
}

.sub-menu-item:hover{
  background-color: var(--hover-clr);
  color: var(--secondary-text-clr);
}

.menu-chevron.rotate{
  rotate: 180deg;
}

.btnLogout{
  margin-top: 0px;
  margin-bottom: 8px;
  cursor: link;
}


.btnLogout .menu-icon{
  -unity-background-image-tint-color: var(--logout-clr);
  cursor: link;
}


.btnLogout:hover{
  background-color: var(--logout-clr);
  cursor: link;
}

.btnLogout:hover .menu-text{
  color: var(--secondary-text-clr);
  cursor: link;
}

.btnLogout:hover .menu-icon{
  -unity-background-image-tint-color: var(--secondary-text-clr);
  cursor: link;
}


.btnLogout.active{
  background-color: var(--logout-clr);
  cursor: link;
}

.btnLogout.active .menu-text{
  color: var(--secondary-text-clr);
  cursor: link;
}

.btnLogout.active .menu-icon{
  -unity-background-image-tint-color: var(--secondary-text-clr);
  cursor: link;
}

.brand-logo-img{
  width: 40px;
  height: 40px;
  margin-top: 0px;
  margin-bottom: 8px;
  align-self: center;

  background-image: resource("Icons/logo_light");
  -unity-background-scale-mode: scale-to-fit;
}



